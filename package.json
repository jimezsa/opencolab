{
  "name": "opencolab",
  "version": "0.1.0",
  "description": "Personal multi-agent AI research lab",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.5",
  "bin": {
    "opencolab": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "NODE_NO_WARNINGS=1 node --enable-source-maps --experimental-strip-types src/cli.ts",
    "start": "NODE_NO_WARNINGS=1 node dist/src/cli.js",
    "test": "NODE_NO_WARNINGS=1 node --test dist/tests/**/*.test.js",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^5.9.3"
  }
}
